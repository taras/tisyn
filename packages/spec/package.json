{
  "name": "@tisyn/spec",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/taras/tisyn.git",
    "directory": "packages/spec"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.ts",
      "import": "./dist/markdown/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build && tsc --build tsconfig.authoring.json",
    "test": "vitest run",
    "emit:cli": "node --import tsx scripts/emit-cli-markdown.ts"
  },
  "devDependencies": {
    "@effectionx/vitest": "^0.3.1",
    "@tisyn/agent": "workspace:*",
    "@tisyn/claude-code": "workspace:*",
    "@tisyn/config": "workspace:*",
    "@tisyn/ir": "workspace:*",
    "@tisyn/transport": "workspace:*",
    "effection": "4.0.2",
    "tsx": "^4.21.0",
    "vitest": "^4"
  }
}
