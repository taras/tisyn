    { "path": "packages/kernel" },
    { "path": "packages/durable-streams" },
    { "path": "packages/runtime" },
    { "path": "packages/agent" },
    { "path": "packages/conformance" },
    { "path": "packages/compiler" },
    { "path": "packages/protocol" },
    { "path": "packages/transport" }
  ]
}
